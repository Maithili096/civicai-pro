# CivicAI-Pro environment variables
# Copy this to .env and fill in your keys

# ── REQUIRED (pick at least one LLM) ──────────────────────────────────────────
GROQ_API_KEY=your_groq_key_here          # Free at console.groq.com — RECOMMENDED
# OPENAI_API_KEY=sk-...                  # Fallback
# HF_API_TOKEN=hf_...                    # HuggingFace Inference API (optional)

# ── OPTIONAL ──────────────────────────────────────────────────────────────────
LLM_PROVIDER=groq                        # groq | openai | hf
LOG_LEVEL=INFO
